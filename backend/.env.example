# Copie este arquivo para .env e ajuste com seus valores reais.
# NUNCA commite o arquivo .env (já está no .gitignore).

# DB_SERVER aceita o formato "IP,PORTA" quando a porta não é a padrão (1433)
# Exemplo: 181.41.170.237,1319
# Use "false" quando tiver usuário/senha de SQL (não Windows)
DB_SERVER=seu-servidor,porta
DB_DATABASE=nome_do_banco
DB_USE_WINDOWS_AUTH=false
DB_USER=seu_usuario
DB_PASSWORD=sua_senha
DB_DRIVER=ODBC Driver 18 for SQL Server
TABELA_FATO=TFato Geral2
TABELA_LEADTIME=Leadtime

# Domínio do frontend publicado no Vercel
FRONTEND_ORIGIN=https://seu-projeto.vercel.app

DEBUG=false
